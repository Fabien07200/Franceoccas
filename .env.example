# ─── Application ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Base de données PostgreSQL ──────────────────────────────
DATABASE_URL=postgresql://fo_app:password@localhost:5432/franceoccas
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Auth ────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-min-256-bits
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-256-bits
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── MangoPay (Paiement & Séquestre) ─────────────────────────
MANGOPAY_CLIENT_ID=franceoccas_sandbox
MANGOPAY_API_KEY=your_mangopay_sandbox_key
MANGOPAY_BASE_URL=https://api.sandbox.mangopay.com/v2.01
MANGOPAY_WEBHOOK_SECRET=your_mangopay_webhook_secret
MANGOPAY_ESCROW_WALLET_ID=your_escrow_wallet_id

# ─── Claude API (Intelligence Artificielle) ──────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=1500

# ─── Argus Pro (Cotation véhicule) ───────────────────────────
ARGUS_API_KEY=your_argus_api_key
ARGUS_BASE_URL=https://api.argus.fr/v3
SIV_API_KEY=your_siv_api_key

# ─── AWS S3 (Stockage photos) ────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-west-3
S3_BUCKET_MEDIA=franceoccas-media-dev
CLOUDFRONT_DOMAIN=https://media.franceoccas.fr

# ─── Email (SendGrid) ────────────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@franceoccas.fr
EMAIL_FROM_NAME=FranceOccas.fr

# ─── Livraison ───────────────────────────────────────────────
COLISSIMO_LOGIN=your_colissimo_login
COLISSIMO_PASSWORD=your_colissimo_password
MONDIAL_RELAY_SITE_KEY=FRCTEST
MONDIAL_RELAY_PRIVATE_KEY=your_mondial_relay_key

# ─── Monitoring ──────────────────────────────────────────────
SENTRY_DSN=https://your-key@sentry.io/your-project
